rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public profile documents. Anyone signed in can read;
    // a user can only create/update their own document.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['followerCount', 'followingCount', 'postCount']));
      allow delete: if false;

      match /following/{targetUid} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }
      match /followers/{followerUid} {
        allow read: if isSignedIn();
        allow write: if isOwner(followerUid) || isOwner(uid);
      }
    }

    // Username reservation docs — used to enforce uniqueness at signup.
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Posts: published posts are readable by anyone signed in;
    // drafts are only readable by their author.
    match /posts/{postId} {
      allow read: if isSignedIn() &&
        (resource.data.published == true || resource.data.authorId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likeCount', 'commentCount']));
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /likes/{uid} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(uid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }
  }
}
